# Routes
# This file defines all application routes (Higher priority routes first)
# https://www.playframework.com/documentation/latest/ScalaRouting
# ~~~~

# An example controller showing a sample home page
GET           /                     controllers.api.UserController.viewIndex()
GET           /users/:id            controllers.api.UserController.viewShow(id: String)

GET           /api/users            controllers.api.UserController.index()
POST          /api/users            controllers.api.UserController.store()
GET           /api/users/:id        controllers.api.UserController.show(id: String)
PATCH         /api/users/:id        controllers.api.UserController.update(id: String)
DELETE        /api/users/:id        controllers.api.UserController.delete(id: String)

# Map static resources from the /public folder to the /assets URL path
GET           /assets/*file         controllers.Assets.versioned(path="/public", file: Asset)
